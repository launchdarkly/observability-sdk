<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/webview_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="#FFFFFF00"
                android:text="android.webkit.WebView"
                android:textSize="16sp" />

            <WebView
                android:id="@+id/webview"
                android:layout_width="match_parent"
                android:layout_height="450dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:background="#FFFFFF00"
                android:text="CustomWebView"
                android:textSize="16sp" />

            <com.example.androidobservability.masking.CustomWebView
                android:id="@+id/customWebView"
                android:layout_width="match_parent"
                android:layout_height="450dp" />

        </LinearLayout>
    </ScrollView>

    <TextView
        android:id="@+id/geckoLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF00"
        android:gravity="center"
        android:text="Tap to load GeckoView (device only)"
        android:textSize="16sp" />

    <FrameLayout
        android:id="@+id/geckoContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp" />

    <TextView
        android:id="@+id/customGeckoLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:background="#FFFFFF00"
        android:gravity="center"
        android:text="Tap to load CustomGeckoView (device only)"
        android:textSize="16sp" />

    <FrameLayout
        android:id="@+id/customGeckoContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp" />

</LinearLayout>
