	"name": "@launchdarkly/observability-sdk",
	"private": true,
	"version": "0.0.0",
	"author": "@launchdarkly",
	"workspaces": [
		"e2e",
		"e2e/*",
		"rrweb",
		"rrweb/packages/*",
		"rrweb/packages/plugins/*",
		"sdk/*",
		"sdk/@launchdarkly/*"
	],
	"scripts": {
		"build": "yarn turbo run build --filter '!@highlight-run/rrweb-web-extension' --filter '!nextjs'",
		"build:sdk": "yarn turbo run build --filter '@launchdarkly/*' --filter 'highlight.run'",
		"docs": "yarn turbo run docs",
		"e2e:cloudflare": "yarn turbo run dev --filter cloudflare-worker...",
		"e2e:express": "yarn turbo run dev --filter express...",
		"e2e:nestjs": "yarn turbo run dev --filter nestjs",
		"e2e:nextjs": "yarn turbo run dev --filter nextjs...",
		"e2e:remix": "yarn turbo run dev --filter remix...",
		"enforce-size": "yarn turbo run enforce-size --filter highlight.run...",
		"format-check": "prettier --check --ignore-unknown .",
		"format:all": "prettier --write --ignore-unknown .",
		"lint": "yarn run turbo lint --filter=!@highlight-run/rrweb --filter=!@highlight-run/rrvideo --filter=!@highlight-run/rrweb-rrweb-plugin-console-record --filter=!@highlight-run/rrweb-_monorepo --filter=!@highlight-run/rrweb-all --filter=!@highlight-run/rrweb-record --filter=!@highlight-run/rrweb-replay --filter=!@highlight-run/rrweb-types --filter=!@highlight-run/rrweb-packer --filter=!@highlight-run/rrweb-utils --filter=!@highlight-run/rrweb-web-extension --filter=!@highlight-run/rrweb-snapshot --filter=!@highlight-run/rrweb-player --filter=!@highlight-run/rrdom --filter=!@highlight-run/rrdom-nodejs --filter=!e2e-react-native",
		"prepare": "husky",
		"preinstall": "git submodule update --init --recursive || true",
		"publish": "yarn workspaces foreach -A --include '@launchdarkly/*' --exclude '@launchdarkly/observability-sdk' --exclude '@launchdarkly/observability-shared' npm publish --access public --tolerate-republish --provenance",
		"publish:highlight": "yarn workspaces foreach -A --include '@highlight-run/*' --include 'highlight.run' --exclude '@highlight-run/rrweb*' --exclude '@highlight-run/rrdom*' --exclude '@highlight-run/rrvideo' npm publish --access public --tolerate-republish --provenance",
		"test": "yarn turbo run test --filter=!nextjs --filter=!@highlight-run/rrweb --filter=!@highlight-run/rrvideo --filter=!@highlight-run/rrweb-rrweb-plugin-console-record --filter=!@highlight-run/rrweb-_monorepo --filter=!@highlight-run/rrweb-all --filter=!@highlight-run/rrweb-record --filter=!@highlight-run/rrweb-replay --filter=!@highlight-run/rrweb-types --filter=!@highlight-run/rrweb-packer --filter=!@highlight-run/rrweb-utils --filter=!@highlight-run/rrweb-web-extension --filter=!@highlight-run/rrweb-snapshot --filter=!@highlight-run/rrweb-player --filter=!@highlight-run/rrdom --filter=!@highlight-run/rrdom-nodejs"
	},
