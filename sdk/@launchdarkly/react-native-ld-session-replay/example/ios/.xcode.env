# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# Emit a composed (Metro + Hermes) source map on Release builds. Setting
# SOURCEMAP_FILE makes react-native-xcode.sh generate the map from the exact
# bundle it compiles and ships, so it can never drift from the running build --
# the root cause of "error extracting true error info from source map".
#
# It's written into ../build so it lands next to the artifacts the README
# uploads via `ldcli symbols upload --path ./build`. $PODS_ROOT is guaranteed
# set here (with-environment.sh uses it to locate this file): it is ios/Pods, so
# ../../build resolves to example/build. Debug builds run Metro and skip
# bundling, so this is a no-op there. Export SOURCEMAP_FILE yourself to override.
if [ -z "$SOURCEMAP_FILE" ]; then
  export SOURCEMAP_FILE="$PODS_ROOT/../../build/main.jsbundle.map"
fi
mkdir -p "$(dirname "$SOURCEMAP_FILE")"

# Tell the LaunchDarkly Metro plugin exactly where to drop the symbols-id
# sidecar: right next to the composed map above, named <map>.symbolsid. Metro
# only hands the serializer the map basename, so without this the sidecar would
# land in Metro's cwd (not ./build) and `ldcli symbols upload` couldn't key this
# map by the id the app reports (Symbols Id Lane).
if [ -z "$LD_SYMBOLS_ID_SIDECAR" ]; then
  export LD_SYMBOLS_ID_SIDECAR="${SOURCEMAP_FILE}.symbolsid"
fi
