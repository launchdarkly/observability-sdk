# Copy to .env and fill in your values. The .env file is gitignored.
#
# LaunchDarkly mobile key used by the example.
LAUNCHDARKLY_MOBILE_KEY=mob-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# OTLP exporter endpoint for observability (defaults to production if unset).
LAUNCHDARKLY_OTLP_ENDPOINT=https://otel.observability.app.launchdarkly.com:4318
# Observability backend URL (defaults to production if unset).
LAUNCHDARKLY_BACKEND_URL=https://pub.observability.app.launchdarkly.com/
