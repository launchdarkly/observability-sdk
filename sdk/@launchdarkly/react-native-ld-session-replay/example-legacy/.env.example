# Copy to .env and fill in your values. The .env file is gitignored.
#
# Selects which LaunchDarkly instance to target for the client-side URLs (flag
# streaming + identify). One of 'production' | 'staging'; the bundle lives in
# src/ldEnvironments.ts. Add a new environment there to support more.
LAUNCHDARKLY_ENV=production
#
# LaunchDarkly mobile key for the selected environment. This is a per-environment
# secret and cannot be derived — make sure it matches LAUNCHDARKLY_ENV above,
# otherwise flag streaming/identify fails with 401.
LAUNCHDARKLY_MOBILE_KEY=mob-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# Optional: override the observability endpoints (traces/logs + session replay
# upload) independently of LAUNCHDARKLY_ENV. Leave unset/blank to use the bundled
# defaults for the selected environment. Set these to point at localhost or an
# arbitrary staging server, e.g.:
#   LAUNCHDARKLY_OTLP_ENDPOINT=http://localhost:4318
#   LAUNCHDARKLY_BACKEND_URL=http://localhost:8082/public
# NOTE: BACKEND_URL is the GraphQL/session-replay upload endpoint used as-is (no
# path appended). The local backend serves the public graph under /public, so
# the localhost value must keep the /public suffix or uploads return 404.
LAUNCHDARKLY_OTLP_ENDPOINT=
LAUNCHDARKLY_BACKEND_URL=
