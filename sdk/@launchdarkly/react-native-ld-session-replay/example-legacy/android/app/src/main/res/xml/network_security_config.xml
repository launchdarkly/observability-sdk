<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext HTTP ONLY to local dev hosts so pointing the
         observability/session-replay endpoints at a localhost backend works in
         any build variant (release included). 10.0.2.2 is the Android emulator's
         alias for the host loopback; Genymotion uses 10.0.3.2. Everything else
         (real production HTTPS endpoints) keeps cleartext disabled. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">10.0.3.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
